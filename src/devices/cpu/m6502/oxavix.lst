	read_zeropage(m_TMP2); // dummy read
	m_TMP2 += m_X;
	m_TMP = read_zeropage(m_TMP2 & 0xff);
	m_TMP = set_h(m_TMP, read_zeropage((m_TMP2+1) & 0xff));
	m_TMP2 = read(m_TMP);
	m_A |= m_TMP2;
	set_nz(m_A);
	prefetch();

