jmp_m_ind
	// JMP ($m_Xm_XFF) has the same bug as on the NMOS 6502
	m_TMP = read_pc();
	m_PC++;
	m_TMP = set_h(m_TMP, read_pc());
	m_PC++;
	m_PC = read_data(m_TMP);
	m_PC = set_h(m_PC, read_data(set_l(m_TMP, m_TMP+1)));
	prefetch();

jsr_m_adr
	m_TMP = read_pc();
	m_PC++;
	read_dummy(m_SP);
	write(m_SP, m_PC>>8);
	dec_SP();
	write(m_SP, m_PC);
	dec_SP();
	m_TMP = set_h(m_TMP, read_pc());
	m_PC++;
	m_PC = m_TMP;
