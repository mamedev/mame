# m740 opcodes
set_imp
	read_pc();
	m_P |= F_T;
	m_inst_state_base = 0x100;
	prefetch();

clt_imp
	read_pc();
	m_P &= ~F_T;
	m_inst_state_base = 0;
	prefetch();

ldm_imz
	m_TMP = read_pc();
	m_PC++;
	m_TMP2 = read_pc();
	m_PC++;
	write(m_TMP2, m_TMP);
	prefetch();

dec_acc
	read_pc();
	m_A--;
	set_nz(m_A);
	prefetch();

inc_acc
	read_pc();
	m_A++;
	set_nz(m_A);
	prefetch();

jsr_spg
	m_TMP = read_pc();
	read_dummy(m_SP);
	write(m_SP, m_PC>>8);
	dec_SP();
	write(m_SP, m_PC);
	dec_SP();
	m_TMP = set_h(m_TMP, 0xff);
	m_PC = m_TMP;
	prefetch();

clb_bac
	read_pc();
	m_A = do_clb(m_A, (m_IR>>5) & 7);
	prefetch();

seb_bac
	read_pc();
	m_A = do_seb(m_A, (m_IR>>5) & 7);
	prefetch();

clb_biz
	m_TMP = read_pc();
	m_PC++;
	m_TMP2 = read(m_TMP);
	read_dummy(m_TMP);
	m_TMP2 = do_clb(m_TMP2, (m_IR>>5) & 7);
	write(m_TMP, m_TMP2);
	prefetch();

seb_biz
	m_TMP = read_pc();
	m_PC++;
	m_TMP2 = read(m_TMP);
	read_dummy(m_TMP);
	m_TMP2 = do_seb(m_TMP2, (m_IR>>5) & 7);
	write(m_TMP, m_TMP2);
	prefetch();

bbc_bzr
	m_TMP = read_pc();
	m_PC++;
	m_TMP2 = read(m_TMP);
	read_pc();
	if(!(m_TMP2 & (1 << ((m_IR>>5) & 7)))) {
		m_TMP = read_pc();
		read_dummy(set_l(m_PC, m_PC+1));
		m_PC++;
		read_dummy(set_l(m_PC, m_PC+int8_t(m_TMP)));
		m_PC += int8_t(m_TMP);
	} else {
		read_pc();
		m_PC++;
	}
	prefetch();

bbs_bzr
	m_TMP = read_pc();
	m_PC++;
	m_TMP2 = read(m_TMP);
	read_pc();
	if(m_TMP2 & (1 << ((m_IR>>5) & 7))) {
		m_TMP = read_pc();
		read_dummy(set_l(m_PC, m_PC+1));
		m_PC++;
		read_dummy(set_l(m_PC, m_PC+int8_t(m_TMP)));
		m_PC += int8_t(m_TMP);
	} else {
		read_pc();
		m_PC++;
	}
	prefetch();

bbc_bar
	read_pc();
	read_pc();
	if(!(m_A & (1 << ((m_IR>>5) & 7)))) {
		m_TMP = read_pc();
		read_dummy(set_l(m_PC, m_PC+1));
		m_PC++;
		read_dummy(set_l(m_PC, m_PC+int8_t(m_TMP)));
		m_PC += int8_t(m_TMP);
	} else {
		read_pc();
		m_PC++;
	}
	prefetch();

bbs_bar
	read_pc();
	read_pc();
	if(m_A & (1 << ((m_IR>>5) & 7))) {
		m_TMP = read_pc();
		read_dummy(set_l(m_PC, m_PC+1));
		m_PC++;
		read_dummy(set_l(m_PC, m_PC+int8_t(m_TMP)));
		m_PC += int8_t(m_TMP);
	} else {
		read_pc();
		m_PC++;
	}
	prefetch();

com_zpg
	m_TMP = read_pc();
	m_PC++;
	m_TMP2 = read(m_TMP);
	read_dummy(m_TMP);
	m_TMP2 ^= 0xff;
	set_nz(m_TMP2);
	write(m_TMP, m_TMP2);
	prefetch();

rrf_zpg
	m_TMP = read_pc();
	m_PC++;
	m_TMP2 = read(m_TMP);
	read_dummy(m_TMP);
	read_dummy(m_TMP);
	read_dummy(m_TMP);
	read_dummy(m_TMP);
	m_TMP2 = do_rrf(m_TMP2);
	write(m_TMP, m_TMP2);
	prefetch();

tst_zpg
	m_TMP = read_pc();
	m_PC++;
	m_TMP2 = read(m_TMP);
	set_nz(m_TMP2);
	prefetch();

bra_rel
	m_TMP = read_pc();
	read_dummy(set_l(m_PC, m_PC+1));
	m_PC++;
	read_dummy(set_l(m_PC, m_PC+int8_t(m_TMP)));
	m_PC += int8_t(m_TMP);
	prefetch();

jmp_zpi
	m_TMP2 = read_pc();
	m_TMP = read(m_TMP2 & 0xff);
	m_TMP = set_h(m_TMP, read((m_TMP2+1) & 0xff));
	m_PC = m_TMP;
	prefetch();

jsr_zpi
	m_TMP2 = read_pc();
	read_dummy(m_SP);
	write(m_SP, m_PC>>8);
	dec_SP();
	write(m_SP, m_PC);
	dec_SP();
	m_TMP = read(m_TMP2 & 0xff);
	m_TMP = set_h(m_TMP, read((m_TMP2+1) & 0xff));
	m_PC = m_TMP;
	prefetch();

stp_imp
	read_pc();
	logerror("STP at $%04x\n", m_PC);
	while(!m_irq_state) {
		eat-all-cycles;
	}
	prefetch();

wit_imp
	read_pc();
	logerror("WIT at $%04x\n", m_PC);
	while(!m_irq_state) {
		eat-all-cycles;
	}
	prefetch();

reset_m
	m_P |= F_I;
	read_dummy(m_SP);
	dec_SP();
	read_dummy(m_SP);
	dec_SP();
	read_dummy(m_SP);
	dec_SP();
	m_PC = read_arg(0xfffe);
	m_PC = set_h(m_PC, read_arg(0xffff));
	prefetch();
	m_inst_state = -1;

brk_m_imp
	if(m_irq_taken) {
		read_pc();
	} else {
		read_pc();
		m_PC++;
	}
	write(m_SP, m_PC >> 8);
	dec_SP();
	write(m_SP, m_PC);
	dec_SP();
	write(m_SP, m_irq_taken ? m_P & ~F_B : m_P);
	dec_SP();
	// BRK uses the vector of the interrupt with the highest priority if any are enabled and pending
	if(m_irq_taken)
		standard_irq_callback(IRQ_LINE, m_PC);
	m_PC = read_arg(m_irq_vector);
	m_PC = set_h(m_PC, read_arg(m_irq_vector+1));
	m_irq_taken = false;
	m_P |= F_I; // Do *not* move after the prefetch
	prefetch();
	m_inst_state = -1;

# 6502 opcodes with modified access patterns

adc_m_abx
	m_TMP = read_pc();
	m_PC++;
	m_TMP = set_h(m_TMP, read_pc());
	m_PC++;
	read_dummy(set_l(m_TMP, m_TMP+m_X));
	m_TMP += m_X;
	m_TMP2 = read(m_TMP);
	do_adc(m_TMP2);
	prefetch();

adc_m_aby
	m_TMP = read_pc();
	m_PC++;
	m_TMP = set_h(m_TMP, read_pc());
	m_PC++;
	read_dummy(set_l(m_TMP, m_TMP+m_Y));
	m_TMP += m_Y;
	m_TMP2 = read(m_TMP);
	do_adc(m_TMP2);
	prefetch();

adc_m_idx
	m_TMP2 = read_pc();
	read_dummy(m_PC & 0xff);
	m_PC++;
	m_TMP2 += m_X;
	m_TMP = read(m_TMP2 & 0xff);
	m_TMP = set_h(m_TMP, read((m_TMP2+1) & 0xff));
	m_TMP2 = read_data(m_TMP);
	do_adc(m_TMP2);
	prefetch();

adc_m_idy
	m_TMP2 = read_pc();
	m_PC++;
	m_TMP = read(m_TMP2);
	m_TMP = set_h(m_TMP, read((m_TMP2+1) & 0xff));
	read_dummy(set_l(m_TMP, m_TMP+m_Y));
	m_TMP2 = read_data(m_TMP+m_Y);
	do_adc(m_TMP2);
	prefetch();

adc_m_zpx
	m_TMP = read_pc();
	read_dummy(m_PC & 0xff);
	m_PC++;
	m_TMP2 = read(uint8_t(m_TMP+m_X));
	do_adc(m_TMP2);
	prefetch();

