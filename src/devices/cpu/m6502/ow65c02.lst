# w65c02 opcodes

adc_c_aba
	m_TMP = read_pc();
	m_PC++;
	m_TMP = set_h(m_TMP, read_pc());
	m_PC++;
	m_TMP2 = read(m_TMP);
	do_adc(m_TMP2);
	if(m_P & F_D) {
		read_pc();
		set_nz(m_A);
	}
	prefetch();

adc_c_abx
	m_TMP = read_pc();
	m_PC++;
	m_TMP = set_h(m_TMP, read_pc());
	m_PC++;
	if(page_changing(m_TMP, m_X)) {
		read(set_l(m_TMP, m_TMP+m_X));
	}
	m_TMP += m_X;
	m_TMP2 = read(m_TMP);
	do_adc(m_TMP2);
	if(m_P & F_D) {
		read_pc();
		set_nz(m_A);
	}
	prefetch();

adc_c_aby
	m_TMP = read_pc();
	m_PC++;
	m_TMP = set_h(m_TMP, read_pc());
	m_PC++;
	if(page_changing(m_TMP, m_Y)) {
		read(set_l(m_TMP, m_TMP+m_Y));
	}
	m_TMP += m_Y;
	m_TMP2 = read(m_TMP);
	do_adc(m_TMP2);
	if(m_P & F_D) {
		read_pc();
		set_nz(m_A);
	}
	prefetch();

adc_c_idx
	m_TMP2 = read_pc();
	m_PC++;
	read(m_TMP2);
	m_TMP2 += m_X;
	m_TMP = read(m_TMP2 & 0xff);
	m_TMP = set_h(m_TMP, read((m_TMP2+1) & 0xff));
	m_TMP2 = read(m_TMP);
	do_adc(m_TMP2);
	if(m_P & F_D) {
		read_pc();
		set_nz(m_A);
	}
	prefetch();

adc_c_idy
	m_TMP2 = read_pc();
	m_PC++;
	m_TMP = read(m_TMP2);
	m_TMP = set_h(m_TMP, read((m_TMP2+1) & 0xff));
	if(page_changing(m_TMP, m_Y)) {
		read(set_l(m_TMP, m_TMP+m_Y));
	}
	m_TMP2 = read(m_TMP+m_Y);
	do_adc(m_TMP2);
	if(m_P & F_D) {
		read_pc();
		set_nz(m_A);
	}
	prefetch();

