		set_nz(m_A);
	}
	prefetch();

smb_bzp
	m_TMP = read_pc();
	m_PC++;
	m_TMP2 = read(m_TMP);
	read(m_TMP);
	m_TMP2 |= 1 << ((m_inst_state >> 4) & 7);
	write(m_TMP, m_TMP2);
	prefetch();

sta_zpi
	m_TMP2 = read_pc();
	m_PC++;
	m_TMP = read(m_TMP2 & 0xff);
	m_TMP = set_h(m_TMP, read((m_TMP2+1) & 0xff));
	write(m_TMP, m_A);
	prefetch();

stp_imp
	for(;;) {
		eat-all-cycles;
	}

stz_aba
	m_TMP = read_pc();
	m_PC++;
	m_TMP = set_h(m_TMP, read_pc());
	m_PC++;
	write(m_TMP, 0x00);
	prefetch();

stz_abx
	m_TMP = read_pc();
	m_PC++;
	m_TMP = set_h(m_TMP, read_pc());
	m_PC++;
	read(set_l(m_TMP, m_TMP+m_X));
	write(m_TMP+m_X, 0x00);
	prefetch();

stz_zpg
	m_TMP = read_pc();
	m_PC++;
	write(m_TMP, 0x00);
	prefetch();

stz_zpx
	m_TMP = read_pc();
	m_PC++;
	read(m_TMP);
	write(uint8_t(m_TMP+m_X), 0x00);
	prefetch();

trb_aba
	m_TMP = read_pc();
	m_PC++;
	m_TMP = set_h(m_TMP, read_pc());
	m_PC++;
	m_TMP2 = read(m_TMP);
	read(m_TMP);
	if(m_A & m_TMP2)
		m_P &= ~F_Z;
	else
		m_P |= F_Z;
	m_TMP2 &= ~m_A;
	write(m_TMP, m_TMP2);
	prefetch();

trb_zpg
	m_TMP = read_pc();
	m_PC++;
	m_TMP2 = read(m_TMP);
	read(m_TMP);
	if(m_A & m_TMP2)
		m_P &= ~F_Z;
