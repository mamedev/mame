	}
	m_TMP += m_X;
	m_TMP2 = read(m_TMP);
	do_bit(m_TMP2);
	prefetch();

bit_imm
	m_TMP = read_pc();
	m_PC++;
	if(m_A & m_TMP)
		m_P &= ~F_Z;
	else
		m_P |= F_Z;
	prefetch();

bit_zpx
	m_TMP = read_pc();
	m_PC++;
	read(m_TMP);
	m_TMP2 = read(uint8_t(m_TMP+m_X));
	do_bit(m_TMP2);
	prefetch();

bra_rel
	m_TMP = read_pc();
	m_PC++;
	read_pc();
	if(page_changing(m_PC, int8_t(m_TMP))) {
		read_arg(set_l(m_PC, m_PC+int8_t(m_TMP)));
	}
	m_PC += int8_t(m_TMP);
	prefetch();

brk_c_imp
	if(m_irq_taken || m_nmi_pending) {
		read_pc();
	} else {
		read_pc();
	m_PC++;
	}
	write(m_SP, m_PC >> 8);
	dec_SP();
	write(m_SP, m_PC);
	dec_SP();
	write(m_SP, m_irq_taken || m_nmi_pending ? m_P & ~F_B : m_P);
	dec_SP();
	if(m_irq_taken && m_nmi_pending) {
		standard_irq_callback(NMI_LINE, m_PC);
		m_PC = read_arg(0xfffa);
		m_PC = set_h(m_PC, read_arg(0xfffb));
		m_nmi_pending = false;
	} else {
		if(m_irq_taken)
			standard_irq_callback(IRQ_LINE, m_PC);
		m_PC = read_arg(0xfffe);
		m_PC = set_h(m_PC, read_arg(0xffff));
	}
	m_irq_taken = false;
	m_P = (m_P | F_I) & ~F_D; // Do *not* move after the prefetch
	prefetch();
	m_inst_state = -1;

cmp_zpi
	m_TMP2 = read_pc();
	m_PC++;
	m_TMP = read(m_TMP2 & 0xff);
	m_TMP = set_h(m_TMP, read((m_TMP2+1) & 0xff));
	m_TMP2 = read(m_TMP);
	do_cmp(m_A, m_TMP2);
	prefetch();

dec_acc
	read_pc();
	m_A--;
	set_nz(m_A);
	prefetch();

dec_c_aba
	m_TMP = read_pc();
	m_PC++;
	m_TMP = set_h(m_TMP, read_pc());
	m_PC++;
	m_TMP2 = read(m_TMP);
	read(m_TMP);
	m_TMP2--;
	set_nz(m_TMP2);
	write(m_TMP, m_TMP2);
	prefetch();

