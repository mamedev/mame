	m_TMP = read_pc();
	m_PC++;
	m_TMP = set_h(m_TMP, read_pc());
	m_PC++;
	m_TMP2 = read(m_TMP);
	read(m_TMP);
	m_TMP2 = do_asl(m_TMP2);
	write(m_TMP, m_TMP2);
	prefetch();

asl_c_abx
	m_TMP = read_pc();
	m_PC++;
	m_TMP = set_h(m_TMP, read_pc());
