		m_P |= F_Z;
	m_TMP2 &= ~m_A;
	write(m_TMP, m_TMP2);
	prefetch();

tsb_aba
	m_TMP = read_pc();
	m_PC++;
	m_TMP = set_h(m_TMP, read_pc());
	m_PC++;
	m_TMP2 = read(m_TMP);
	read(m_TMP);
	if(m_A & m_TMP2)
		m_P &= ~F_Z;
	else
		m_P |= F_Z;
	m_TMP2 |= m_A;
	write(m_TMP, m_TMP2);
	prefetch();

tsb_zpg
	m_TMP = read_pc();
	m_PC++;
	m_TMP2 = read(m_TMP);
	read(m_TMP);
	if(m_A & m_TMP2)
		m_P &= ~F_Z;
	else
		m_P |= F_Z;
	m_TMP2 |= m_A;
	write(m_TMP, m_TMP2);
	prefetch();

wai_imp
	read_pc();
	read_pc();
	while(!m_nmi_pending && !m_irq_state) {
		eat-all-cycles;
	}
	prefetch();

#   exceptions
reset_c
	read_arg(0xffff);
	read_pc();
	read(m_SP);
	dec_SP();
	read(m_SP);
	dec_SP();
	read(m_SP);
	dec_SP();
	m_P = (m_P | F_I) & ~F_D;
	m_PC = read_arg(0xfffc);
	m_PC = set_h(m_PC, read_arg(0xfffd));
	prefetch();
	m_inst_state = -1;
