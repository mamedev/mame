# vt3xx_spu opcodes

phy_vt_imp
	read_pc();
	write(m_SP, m_Y);
	dec_SP();
	prefetch();

phx_vt_imp
	read_pc();
	write(m_SP, m_X);
	dec_SP();
	prefetch();

plx_vt_imp
	read_pc();
	read(m_SP);
	inc_SP();
	m_X = read(m_SP);
	set_nz(m_X);
	prefetch();

ply_vt_imp
	read_pc();
	read(m_SP);
	inc_SP();
	m_Y = read(m_SP);
	set_nz(m_Y);
	prefetch();

vtgetdbk_imp
	read_pc();
	m_A = m_databank;
	prefetch();

vtsetdbk_imp
	read_pc();
	m_databank = m_A;
	prefetch();

vtldabank_abx
	m_TMP = read_pc();
	m_PC++;
	m_TMP2 = read_pc();
	m_PC++;
	m_A = m_extdata_space->read_byte(((m_databank << 16) | (m_TMP2 << 8) | m_TMP) + m_X);
	set_nz(m_A);
	prefetch();

vtldabank_idy
	m_TMP2 = read_pc();
	m_PC++;
	m_TMP = read(m_TMP2);
	m_TMP = set_h(m_TMP, read((m_TMP2+1) & 0xff));
	if(page_changing(m_TMP, m_Y)) {
		read(set_l(m_TMP, m_TMP+m_Y));
	}
	m_A = m_extdata_space->read_byte((m_databank << 16) | (m_TMP+m_Y) );
	set_nz(m_A);
	prefetch();

vtadcx_aba
	m_TMP = read_pc();
	m_PC++;
	m_TMP = set_h(m_TMP, read_pc());
	m_PC++;
	m_TMP2 = read(m_TMP);
	m_TMP = m_TMP2 + m_X + (m_P & F_C ? 1 : 0); // do m_ADC, but with source + result in m_X
	m_P &= ~(F_N|F_V|F_Z|F_C);
	if(!uint8_t(m_TMP)) m_P |= F_Z;
	else if(int8_t(m_TMP) < 0) m_P |= F_N;
	if(~(m_TMP2^m_X) & (m_TMP2^m_TMP) & 0x80) m_P |= F_V;
	if(m_TMP & 0xff00) m_P |= F_C;
	m_X = m_TMP & 0xff;
	prefetch();
