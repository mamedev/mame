		read_pc();
	}
	m_TMP2 = read(m_TMP+m_Y);
	do_sbc_c(m_TMP2);
	if(m_P & F_D) {
		read_pc();
		set_nz(m_A);
	}
	m_PC++;
	prefetch();

sbc_s_zpx
	m_TMP = read_pc();
	read_pc();
	m_TMP2 = read(uint8_t(m_TMP+m_X));
	do_sbc_c(m_TMP2);
	if(m_P & F_D) {
		read_pc();
		set_nz(m_A);
	}
	m_PC++;
	prefetch();

sta_s_abx
	m_TMP = read_pc();
	m_PC++;
	m_TMP = set_h(m_TMP, read_pc());
	read_pc();
	m_PC++;
	write(m_TMP+m_X, m_A);
	prefetch();

sta_s_aby
	m_TMP = read_pc();
	m_PC++;
	m_TMP = set_h(m_TMP, read_pc());
	read_pc();
	m_PC++;
	write(m_TMP+m_Y, m_A);
	prefetch();

sta_s_idx
	m_TMP2 = read_pc();
	read_pc();
	m_PC++;
	m_TMP2 += m_X;
	m_TMP = read(m_TMP2 & 0xff);
	m_TMP = set_h(m_TMP, read((m_TMP2+1) & 0xff));
	write(m_TMP, m_A);
