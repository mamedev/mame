rti_s_imp
	read_pc();
	inc_SP();
	m_P = read(m_SP) | (F_B|F_E);
	inc_SP();
	m_TMP = read(m_SP);
	inc_SP();
	m_TMP = set_h(m_TMP, read(m_SP));
	read_pc();
	end_interrupt();
	m_PC = m_TMP;
	prefetch();

rts_s_imp
	read_pc();
	read_pc();
	inc_SP();
	m_TMP = read(m_SP);
	inc_SP();
	m_TMP = set_h(m_TMP, read(m_SP));
	read_pc();
	m_PC = m_TMP + 1;
	prefetch();

sbc_s_abx
	m_TMP = read_pc();
	m_PC++;
	m_TMP = set_h(m_TMP, read_pc());
	if(page_changing(m_TMP, m_X)) {
		read_pc();
	}
	m_TMP += m_X;
	m_TMP2 = read(m_TMP);
	do_sbc_c(m_TMP2);
	if(m_P & F_D) {
		read_pc();
		set_nz(m_A);
	}
	m_PC++;
	prefetch();

sbc_s_aby
	m_TMP = read_pc();
	m_PC++;
	m_TMP = set_h(m_TMP, read_pc());
	if(page_changing(m_TMP, m_Y)) {
		read_pc();
	}
	m_TMP += m_Y;
	m_TMP2 = read(m_TMP);
	do_sbc_c(m_TMP2);
	if(m_P & F_D) {
		read_pc();
		set_nz(m_A);
	}
	m_PC++;
	prefetch();

sbc_s_idx
	m_TMP2 = read_pc();
	read_pc();
	m_TMP2 += m_X;
	m_TMP = read(m_TMP2 & 0xff);
	m_TMP = set_h(m_TMP, read((m_TMP2+1) & 0xff));
	m_TMP2 = read(m_TMP);
	do_sbc_c(m_TMP2);
	if(m_P & F_D) {
		read_pc();
		set_nz(m_A);
	}
	m_PC++;
	prefetch();

sbc_s_idy
	m_TMP2 = read_pc();
	m_TMP = read(m_TMP2);
	m_TMP = set_h(m_TMP, read((m_TMP2+1) & 0xff));
