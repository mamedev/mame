stx_s_zpy
	m_TMP = read_pc();
	read_pc();
	m_PC++;
	write(uint8_t(m_TMP+m_Y), m_X);
	prefetch();

sty_s_zpx
	m_TMP = read_pc();
	read_pc();
	m_PC++;
	write(uint8_t(m_TMP+m_X), m_Y);
	prefetch();

stz_s_abx
	m_TMP = read_pc();
	m_PC++;
	m_TMP = set_h(m_TMP, read_pc());
	read_pc();
	m_PC++;
	write(m_TMP+m_X, 0x00);
