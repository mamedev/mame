# w65c02s opcodes

adc_s_abx
	m_TMP = read_pc();
	m_PC++;
	m_TMP = set_h(m_TMP, read_pc());
	if(page_changing(m_TMP, m_X)) {
		read_pc();
	}
	m_TMP += m_X;
	m_TMP2 = read(m_TMP);
	do_adc(m_TMP2);
	if(m_P & F_D) {
		read_pc();
		set_nz(m_A);
	}
	m_PC++;
	prefetch();

adc_s_aby
	m_TMP = read_pc();
	m_PC++;
	m_TMP = set_h(m_TMP, read_pc());
