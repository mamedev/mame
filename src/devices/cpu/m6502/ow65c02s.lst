stz_s_zpx
	m_TMP = read_pc();
	read_pc();
	m_PC++;
	write(uint8_t(m_TMP+m_X), 0x00);
	prefetch();

trb_s_zpg
	m_TMP = read_pc();
	m_PC++;
	m_TMP2 = read(m_TMP);
	read((m_TMP+1) & 0xff);
	if(m_A & m_TMP2)
		m_P &= ~F_Z;
	else
		m_P |= F_Z;
	m_TMP2 &= ~m_A;
	write(m_TMP, m_TMP2);
	prefetch();

tsb_s_zpg
	m_TMP = read_pc();
	m_PC++;
	m_TMP2 = read(m_TMP);
	read((m_TMP+1) & 0xff);
	if(m_A & m_TMP2)
		m_P &= ~F_Z;
	else
		m_P |= F_Z;
	m_TMP2 |= m_A;
	write(m_TMP, m_TMP2);
	prefetch();

#   exceptions
reset_s
	read_arg(0xffff);
	read_pc();
	read(m_SP);
	dec_SP();
	read(m_SP);
	dec_SP();
	read(m_SP);
	dec_SP();
	m_P = (m_P | F_I) & ~F_D;
	m_PC = read_vector(0xfffc);
	m_PC = set_h(m_PC, read_vector(0xfffd));
	prefetch();
	m_inst_state = -1;
