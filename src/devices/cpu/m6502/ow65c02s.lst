sta_s_idy
	m_TMP2 = read_pc();
	m_TMP = read(m_TMP2);
	m_TMP = set_h(m_TMP, read((m_TMP2+1) & 0xff));
	read_pc();
	m_PC++;
	write(m_TMP+m_Y, m_A);
