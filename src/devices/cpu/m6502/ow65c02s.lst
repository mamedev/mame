	}
	m_TMP += m_Y;
	m_TMP2 = read(m_TMP);
	do_adc(m_TMP2);
	if(m_P & F_D) {
		read_pc();
		set_nz(m_A);
	}
	m_PC++;
	prefetch();

adc_s_idx
	m_TMP2 = read_pc();
	read_pc();
	m_TMP2 += m_X;
	m_TMP = read(m_TMP2 & 0xff);
	m_TMP = set_h(m_TMP, read((m_TMP2+1) & 0xff));
	m_TMP2 = read(m_TMP);
	do_adc(m_TMP2);
	if(m_P & F_D) {
		read_pc();
		set_nz(m_A);
	}
	m_PC++;
