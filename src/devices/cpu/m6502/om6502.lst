# NMOS 6502 opcodes
# Verified with visual6502
#   documented opcodes

adc_aba
	m_TMP = read_pc();
	m_PC++;
	m_TMP = set_h(m_TMP, read_pc());
	m_PC++;
	m_TMP2 = read(m_TMP);
	do_adc(m_TMP2);
	prefetch();

adc_abx
	m_TMP = read_pc();
	m_PC++;
	m_TMP = set_h(m_TMP, read_pc());
	m_PC++;
	if(page_changing(m_TMP, m_X)) {
		read(set_l(m_TMP, m_TMP+m_X));
	}
	m_TMP += m_X;
	m_TMP2 = read(m_TMP);
	do_adc(m_TMP2);
	prefetch();

adc_aby
	m_TMP = read_pc();
	m_PC++;
	m_TMP = set_h(m_TMP, read_pc());
	m_PC++;
	if(page_changing(m_TMP, m_Y)) {
		read(set_l(m_TMP, m_TMP+m_Y));
	}
	m_TMP += m_Y;
	m_TMP2 = read(m_TMP);
	do_adc(m_TMP2);
	prefetch();

adc_idx
	m_TMP2 = read_pc();
	m_PC++;
	read(m_TMP2);
	m_TMP2 += m_X;
	m_TMP = read(m_TMP2 & 0xff);
	m_TMP = set_h(m_TMP, read((m_TMP2+1) & 0xff));
	m_TMP2 = read(m_TMP);
	do_adc(m_TMP2);
	prefetch();

