	m_TMP = set_h(m_TMP, read_pc());
	m_PC++;
	if(page_changing(m_TMP, m_X)) {
		read(set_l(m_TMP, m_TMP+m_X));
	}
	read(m_TMP + m_X);
	prefetch();

nop_imm
	read_pc();
	m_PC++;
	prefetch();

nop_zpg
	m_TMP = read_pc();
	m_PC++;
	read(m_TMP);
	prefetch();

nop_zpx
	m_TMP = read_pc();
	m_PC++;
	read(m_TMP);
	read(uint8_t(m_TMP+m_X));
	prefetch();

# system killers
kil_non
	read_pc();
	m_PC++;
	read(0xffff);
	read(0xfffe);
	read(0xfffe);
	for(;;) {
		read(0xffff);
	}
