	prefetch();

bcc_rel
	m_TMP = read_pc();
	m_PC++;
	if(!(m_P & F_C)) {
		read_pc();
		if(page_changing(m_PC, int8_t(m_TMP))) {
			read_arg(set_l(m_PC, m_PC+int8_t(m_TMP)));
		}
		m_PC += int8_t(m_TMP);
	}
	prefetch();

