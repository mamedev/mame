dew_zpg
	m_TMP2 = read_pc();
	m_PC++;
	m_TMP = read(m_B|m_TMP2);
	m_TMP2++;
	m_TMP = set_h(m_TMP, read(m_B|m_TMP2));
	m_P &= ~(F_N|F_Z);
	m_TMP--;
	if(!m_TMP)
		m_P |= F_Z;
	else if(m_TMP & 0x8000)
		m_P |= F_N;
	m_TMP2--;
	write(m_B|m_TMP2, m_TMP);
	m_TMP2++;
	write(m_B|m_TMP2, m_TMP >> 8);
	prefetch();

dex_ce_imp
	m_X--;
	set_nz(m_X);
	prefetch();

