sta_isy
	read_pc();
	m_TMP = read_pc();
	m_PC++;
	if(m_P & F_E)
		m_TMP = set_l(m_SP, m_SP+m_TMP);
	else
		m_TMP = m_SP + m_TMP;
	m_TMP2 = read(m_TMP);
	m_TMP++;
	m_TMP = m_TMP2 | (read(m_TMP) << 8);
	write(m_TMP+m_Y, m_A);
	prefetch();

