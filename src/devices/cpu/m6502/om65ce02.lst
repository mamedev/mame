row_aba
	m_TMP = read_pc();
	m_PC++;
	m_TMP = set_h(m_TMP, read_pc());
	m_PC++;
	m_TMP3 = read(m_TMP);
	m_TMP3 = set_h(m_TMP3, read(m_TMP+1));
	m_TMP2 = m_P;
	m_P &= ~(F_C|F_N|F_Z);
	if(m_TMP3 & 0x8000)
		m_P |= F_C;
	m_TMP3 <<= 1;
	if(m_TMP2 & F_C)
		m_TMP3 |= 0x0001;
	if(!m_TMP3)
		m_P |= F_Z;
	else if(m_TMP3 & 0x8000)
		m_P |= F_N;
	write(m_TMP, m_TMP3);
	write(m_TMP, m_TMP3 >> 8);
	prefetch();

