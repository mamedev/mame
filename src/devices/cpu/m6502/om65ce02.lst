brk_ce_imp
	if(m_irq_taken) {
		read_pc();
	} else {
		read_pc();
		m_PC++;
	}
	write(m_SP, m_PC >> 8);
	dec_SP_ce();
	write(m_SP, m_PC);
	dec_SP_ce();
	write(m_SP, m_irq_taken || m_nmi_pending ? m_P & ~F_B : m_P);
	dec_SP_ce();
	if(m_nmi_pending) {
		m_PC = read_arg(0xfffa);
		m_PC = set_h(m_PC, read_arg(0xfffb));
		m_nmi_pending = false;
	} else {
		m_PC = read_arg(0xfffe);
		m_PC = set_h(m_PC, read_arg(0xffff));
	}
	m_irq_taken = false;
	m_P = (m_P | F_I) & ~F_D; // Do *not* move after the prefetch
	prefetch();
	m_inst_state = -1;

bsr_rw2
	m_TMP = read_pc();
	m_PC++;
	write(m_SP, m_PC>>8);
	dec_SP_ce();
	write(m_SP, m_PC);
	dec_SP_ce();
	m_TMP = set_h(m_TMP, read_pc());
	m_PC++;
	m_PC += m_TMP-1;
	prefetch();

