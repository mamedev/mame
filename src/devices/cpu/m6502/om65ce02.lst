# 65ce02 opcodes, a lot only remove dummy read/write cycles, some are new, some use the m_B register

adc_ce_aba
	m_TMP = read_pc();
	m_PC++;
	m_TMP = set_h(m_TMP, read_pc());
	m_PC++;
	m_TMP2 = read(m_TMP);
	do_adc(m_TMP2);
	if(m_P & F_D)
		set_nz(m_A);
	prefetch();

