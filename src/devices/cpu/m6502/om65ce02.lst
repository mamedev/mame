	m_TMP2 += m_X;
	m_TMP = read(m_B|m_TMP2);
	m_TMP2++;
	m_TMP = set_h(m_TMP, read(m_B|m_TMP2));
	write(m_TMP, m_A);
	prefetch();

sta_ce_idy
	m_TMP2 = read_pc();
