asw_aba
	m_TMP = read_pc();
	m_PC++;
	m_TMP = set_h(m_TMP, read_pc());
	m_PC++;
	m_TMP3 = read(m_TMP);
	m_TMP3 = set_h(m_TMP3, read(m_TMP+1));
	m_P &= ~(F_C|F_N|F_Z);
	if(m_TMP3 & 0x8000)
		m_P |= F_C;
	m_TMP3 <<= 1;
	if(!m_TMP3)
		m_P |= F_Z;
	else if(m_TMP3 & 0x8000)
		m_P |= F_N;
	write(m_TMP, m_TMP3);
	write(m_TMP, m_TMP3 >> 8);
	prefetch();

aug_iw3
	read_pc();
	m_PC++;
	read_pc();
	m_PC++;
	read_pc();
	m_PC++;
	prefetch();

bbr_ce_zpb
	// Access pattern uncertain
	m_TMP = read_pc();
	m_PC++;
	m_TMP2 = read(m_TMP);
	m_TMP = read_pc();
	m_PC++;
	if(!(m_TMP2 & (1 << ((m_inst_state >> 4) & 7))))
		m_PC += int8_t(m_TMP);
	prefetch();

