			<bounds x="83" y="300" width="32" height="32"/>
			<yscroll name="reel3:scroll" size="0.1875" wrap="yes" min="64854" max="130389"/>
		</element>

		<element name="reel1:pos" ref="Steppers" state="0">
			<bounds x="20" y="330" width="5" height="2"/>
		</element>
