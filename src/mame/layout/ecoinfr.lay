		<element ref="SteppersReel1">
			<bounds x="17" y="300" width="32" height="32"/>
			<yscroll name="reel1:scroll" size="0.1875" wrap="yes" min="64854" max="130389"/>
		</element>
		<element ref="SteppersReel2">
			<bounds x="50" y="300" width="32" height="32"/>
			<yscroll name="reel2:scroll" size="0.1875" wrap="yes" min="64854" max="130389"/>
