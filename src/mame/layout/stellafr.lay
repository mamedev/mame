<?xml version="1.0"?>
<!--
license:CC0-1.0
-->
<mamelayout version="2">

	<element name="led_red" defstate="0">
		<disk state="1"><color red="1.0" green="0.1" blue="0.15" /></disk>
		<disk state="0"><color red="0.17" green="0.015" blue="0.02" /></disk>
	</element>

	<element name="green_led" defstate="0">
		<rect state="0">
			<color red="0" green="0.2" blue="0" />
		</rect>
		<rect state="1">
			<color red="0" green="0.8" blue="0" />
		</rect>
	</element>

<!-- define elements -->
	<element name="static_black">
		<rect>
			<color red="0.0" green="0.0" blue="0.0" />
		</rect>
	</element>

	<element name="digit" defstate="0">
		<led7seg>
			<color red="1.0" green="0.3" blue="0.2" />
		</led7seg>
	</element>

	<element name="coin_led" defstate="0">
		<disk state="1"><color red="1.0" green="0.85" blue="0.2" /></disk>
		<disk state="0"><color red="0.18" green="0.15" blue="0.03" /></disk>
	</element>

	<element name="magnet_ind" defstate="0">
		<rect state="1"><color red="0.2" green="0.5" blue="1.0" /></rect>
		<rect state="0"><color red="0.03" green="0.08" blue="0.18" /></rect>
	</element>

	<view name="Internal Layout">
		<bounds left="0" right="116" top="0" bottom="52" />
		<element ref="static_black">
			<bounds left="0" right="116" top="0" bottom="52" />
		</element>

<!-- ===== in-machine panel ===== -->
		<!-- Sonderspiele / Serien counter (Anzout3, fields 0/1/3) -->
		<element name="digit10" ref="digit"><bounds x="2" y="2" width="11" height="15" /></element>
		<element name="digit13" ref="digit"><bounds x="15" y="2" width="11" height="15" /></element>
		<element name="digit11" ref="digit"><bounds x="28" y="2" width="11" height="15" /></element>
		<!-- Münzspeicher: 3 big (Anzout5, fields 2/0/3) -->
		<element name="digit02" ref="digit"><bounds x="48" y="2" width="13" height="17" /></element>
		<element name="digit00" ref="digit"><bounds x="62" y="2" width="13" height="17" /></element>
		<element name="digit03" ref="digit"><bounds x="76" y="2" width="13" height="17" /></element>
		<!-- Münzspeicher: 2 small (Anzout5 field 1, Anzout3 field 2) -->
		<element name="digit01" ref="digit"><bounds x="94" y="2" width="9" height="12" /></element>
		<element name="digit12" ref="digit"><bounds x="104" y="2" width="9" height="12" /></element>

		<!-- coin-accept LEDs (0,10 / 1 / 2 / 5 DM) + Freispiele + magnets -->
		<element name="anzled0" ref="coin_led"><bounds x="48" y="21" width="3" height="3" /></element>
		<element name="anzled1" ref="coin_led"><bounds x="55" y="21" width="3" height="3" /></element>
		<element name="anzled2" ref="coin_led"><bounds x="62" y="21" width="3" height="3" /></element>
		<element name="anzled3" ref="coin_led"><bounds x="69" y="21" width="3" height="3" /></element>
		<element name="anzled4" ref="coin_led"><bounds x="80" y="21" width="3" height="3" /></element>
		<element name="magnet0" ref="magnet_ind"><bounds x="94" y="21" width="4" height="3" /></element>
		<element name="magnet1" ref="magnet_ind"><bounds x="100" y="21" width="4" height="3" /></element>

		<!-- control unit error LEDs -->
		<element name="led0" ref="led_red"><bounds x="108" y="21" width="3" height="3" /></element>
		<element name="led1" ref="led_red"><bounds x="112" y="21" width="3" height="3" /></element>

		<!-- anz debug grid: digit<anzout><field>, 8 columns x 4 digits -->
		<repeat count="8">
			<param name="a" start="0" increment="1" />
			<param name="x" start="2" increment="6" />
			<repeat count="4">
				<param name="f" start="0" increment="1" />
				<param name="y" start="30" increment="5" />
				<element name="digit~a~~f~" ref="digit">
					<bounds x="~x~" y="~y~" width="5" height="4" />
				</element>
			</repeat>
		</repeat>

		<!-- lamp matrix debug grid -->
		<repeat count="12">
			<param name="s" start="0" increment="1" />
			<param name="x" start="56" increment="2" />
			<repeat count="8">
			<param name="z" start="0" increment="1" />
			<param name="y" start="30" increment="2" />
				<element name="lamp~z~~s~" ref="green_led">
					<bounds x="~x~" y="~y~" width="1" height="1" />
				</element>
			</repeat>
		</repeat>

	</view>
</mamelayout>
